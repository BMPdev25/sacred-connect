{
  "name": "sacred-connect",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test:mobile:success": "node scripts/run-maestro.js flow-booking-success.yaml",
    "test:mobile:accept": "node scripts/run-maestro.js flow-priest-acceptance.yaml",
    "test:mobile:payment": "node scripts/run-maestro.js flow-devotee-payment.yaml",
    "test:mobile:cancel-priest": "node scripts/run-maestro.js flow-priest-cancellation.yaml",
    "test:mobile:cancel-devotee": "node scripts/run-maestro.js flow-devotee-cancellation.yaml",
    "test:mobile:complete": "node scripts/run-maestro.js flow-priest-completion.yaml",
    "test:mobile:rating": "node scripts/run-maestro.js flow-devotee-rating.yaml"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.9.0",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.12.2",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "^55.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-intent-launcher": "~13.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "^55.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-razorpay": "^2.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "baseline-browser-mapping": "^2.8.32",
    "jest": "^30.2.0",
    "jest-expo": "^47.0.1",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "react-native",
    "transform": {
      "^.+\\.(js|ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|expo|@expo|@unimodules|unimodules|react-navigation|@react-navigation|@react-native-community|@expo-google-fonts|expo-asset|expo-font|expo-constants|expo-router|expo-secure-store|expo-document-picker|expo-file-system|expo-modules-core|expo-location|expo-image-picker|expo-notifications|expo-sharing|expo-device|expo-linking|expo-intent-launcher|expo-web-browser|firebase|@react-navigation/native|@react-navigation/native-stack)/"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  }
}
